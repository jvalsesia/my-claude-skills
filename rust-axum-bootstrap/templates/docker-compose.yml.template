services:
  postgres:
    image: postgres:17-alpine
    container_name: {{PROJECT_NAME_SNAKE}}_db
    restart: unless-stopped
    environment:
      POSTGRES_USER: postgres
      POSTGRES_PASSWORD: postgres
      POSTGRES_DB: {{PROJECT_DB_NAME}}
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./docker/init-db.sh:/docker-entrypoint-initdb.d/init-db.sh:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres -d {{PROJECT_DB_NAME}}"]
      interval: 5s
      timeout: 5s
      retries: 10

volumes:
  postgres_data:
